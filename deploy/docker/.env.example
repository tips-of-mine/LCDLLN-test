# ============================================================
# LCDLLN Docker — Variables d'environnement
# ============================================================
# Copier ce fichier en .env et adapter les valeurs.
# Ne jamais committer .env en production.
# ============================================================

# --- MySQL ---------------------------------------------------
MYSQL_ROOT_PASSWORD=lcdlln_root_dev
MYSQL_DATABASE=lcdlln_master
MYSQL_USER=lcdlln_user
MYSQL_PASSWORD=lcdlln_pass_dev

# --- Serveur -------------------------------------------------
SERVER_PORT=3840

# --- Sécurité ------------------------------------------------
# IMPORTANT : changer ce secret en production (min 32 caractères)
LCDLLN_HMAC_SECRET=dev_secret_change_in_production_32chars

# --- Master (ports sur l’hôte Docker) ------------------------
# Adresse d’écoute sur l’hôte : 0.0.0.0 = toutes les interfaces (accès LAN ex. 10.0.4.133:3840 / :3842).
# MASTER_PUBLISH_ADDR=0.0.0.0
# MASTER_PORT=3840
# MASTER_HEALTH_PORT=3842
#
# Client : aligner config/server.ini (status HTTP, master_tcp_host) sur l’IP réelle du serveur.

# --- Shard (adresse annoncée aux clients dans la liste des serveurs) -----------------
# Doit être joignable depuis la machine qui lance le jeu (ex. IP LAN de l’hôte Docker + port publié shard).
# SHARD_REGISTER_ENDPOINT=10.0.4.133:3843
# SHARD_PORT=3843
#
# --- Shard (présentation publique dans la liste des serveurs) ------------------------
# Ces valeurs sont affichées côté client / exposées par l'API /status. Elles
# remplacent l'affichage de l'IP. L'IP/port ne sont JAMAIS affichés au joueur.
# SHARD_DISPLAY_NAME : nom public du serveur (texte libre, remplace l'IP en jaune).
# SHARD_DISPLAY_NAME=Royaume principal
# SHARD_GAME_MODE : mode de jeu — pve | pvp.
# SHARD_GAME_MODE=pve
# SHARD_RULESET : règle — cooperative | competitive | hardcore | roleplay.
# SHARD_RULESET=cooperative
# SHARD_REGION : région annoncée (texte libre, ex. eu-west), visible dans /status.
# SHARD_REGION=eu-west

# --- Traefik (web-portal, phpmyadmin ; master désactivé par défaut) ---
# Le service master a traefik.enable=false tant que l’accès se fait en IP directe.
# Noms des entrypoints dans la config statique Traefik (ex. web / websecure).
# TRAEFIK_ENTRYPOINT_HTTP=http
# TRAEFIK_ENTRYPOINT_HTTPS=https
# TRAEFIK_CERT_RESOLVER=letsencrypt
#
# Quand le master passera derrière Traefik : voir traefik-master.labels.reference.yml (MASTER_HEALTH_HOST, TCP SNI, etc.).
