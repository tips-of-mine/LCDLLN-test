{
    "log": {
        "level": "Info",
        "rotation_size_mb": 10,
        "retention_days": 7
    },
    "render": {
        "vsync": true,
        "present_mode": "fifo",
        "fullscreen": true,
        "auth_ui": {
            "background_path": "ui/login/background.png",
            "background_blit": {
                "enabled": true,
                "fit": "cover_height"
            },
            "minimal_chrome": true,
            "login_art_column": false,
            "logo_path": "ui/login/logo_login.png",
            "logo_size_px": 96,
            "layout": {
                "title_line1_from_panel_top_px": 4,
                "gap_title_to_section_px": 8,
                "title_center_viewport_width": true,
                "field_row_extra_px": 0
            },
            "font_path": "fonts/Windlass.ttf",
            "font_pixel_height": 28
        },
        "terrain": {
            "heightmap": "terrain/heightmap.r16h",
            "splatmap": "",
            "hole_mask": ""
        }
    },
    "audio": {
        "master_volume": 1.0,
        "music_volume": 0.8,
        "sfx_volume": 1.0,
        "ui_volume": 1.0,
        "zone_audio_path": "audio/zone_audio.json",
        "menu_music_path": "audio/Horns_of_the_Fallen_Bastion.mp3"
    },
    "time": {
        "fixed_dt": 0.0
    },
    "camera": {
        "mouse_sensitivity": 0.002
    },
    "shadows": {
        "resolution": 1024,
        "depth_bias_constant": 1.25,
        "depth_bias_slope": 1.75,
        "cull_front_faces": false
    },
    "bloom": {
        "threshold": 1.0,
        "knee": 0.5,
        "intensity": 1.0
    },
    "tonemap": {
        "exposure": 1.0
    },
    "color_grading": {
        "enable": false,
        "lut_path": "",
        "strength": 1.0
    },
    "exposure": {
        "key": 0.18,
        "speed": 2.0,
        "histogram_percentile_low": 0.10,
        "histogram_percentile_high": 0.90
    },
    "world": {
        "max_draw_distance_m": 0.0
    },
    "paths": {
        "content": "game/data"
    },
    "client": {
        "master_port": 3840,
        "server_fingerprint": "",
        "allow_insecure_dev": true,
        "locale": "",
        "character_creation": {
            "default_server_id": 1
        },
        "auth_ui": {
            "enabled": true,
            "timeout_ms": 5000
        },
        "gameplay_udp": {
            "enabled": false,
            "host": "127.0.0.1",
            "port": 27015,
            "character_key": 1,
            "request_tick_hz": 20,
            "request_snapshot_hz": 10,
            "vendor_talk_target": "vendor:1",
            "auction_talk_target": "auction"
        }
    }
}