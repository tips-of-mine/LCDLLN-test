# Copier vers .env.local pour le dev local (ne pas committer les secrets)
# Base MySQL (portail API — à brancher)
# DATABASE_URL=mysql://lcdlln_user:password@127.0.0.1:3306/lcdlln_master
# JWT / session
# AUTH_SECRET=change_me_long_random
# URL publique du portail (pour liens dans e-mails)
# NEXT_PUBLIC_PORTAL_URL=https://portal.example.com
# SMTP pour les liens de reinitialisation
# SMTP_HOST=127.0.0.1
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=no-reply@example.com
