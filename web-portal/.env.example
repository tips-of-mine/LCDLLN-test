# Variables d'environnement du web-portal (LCDLLN).
# Copier en `.env.local` (dev) ou fournir via Docker .env / systemd EnvironmentFile.
# NE JAMAIS committer le fichier rempli : il contient des secrets.

# --- Obligatoires ---

# Connexion MySQL au schema lcdlln_master.
# Format : mysql://user:password@host:port/database
DATABASE_URL=mysql://lcdlln:changeme@127.0.0.1:3306/lcdlln_master

# Secret serveur utilise pour le HMAC-SHA256 des reponses aux questions secretes
# et le hash des tokens de reset (lib/auth/passwordRecovery.ts). OBLIGATOIRE des
# qu'on enregistre un profil de recuperation ou qu'on utilise "mot de passe oublie".
# Generer une valeur aleatoire forte, ex. :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ou : openssl rand -hex 32
AUTH_SECRET=

# URL publique du portail (liens dans les e-mails, ex. reset password).
PORTAL_URL=https://portail.exemple.fr
NEXT_PUBLIC_PORTAL_URL=https://portail.exemple.fr

# --- E-mail (SMTP) ---
# Requis pour l'envoi des e-mails (verification, reset password, CGU). Si absent,
# l'envoi est desactive (cf. lib/email/sender.ts).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@exemple.fr

# --- Optionnel ---

# URL de base du HealthEndpoint du master (pastille "en ligne" dans
# Admin > Gestion des joueurs, route GET /online-accounts). Si absent ou master
# injoignable : degradation gracieuse, aucune pastille (page fonctionnelle).
MASTER_STATUS_URL=http://127.0.0.1:3842
