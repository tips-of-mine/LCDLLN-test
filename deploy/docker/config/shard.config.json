{
  "server": {
    "tcp": { "port": 3843 },
    "health": { "port": 3844, "bind": "0.0.0.0" },
    "listen_port": 27015
  },
  "shard": {
    "id": 1,
    "ticket_hmac_secret": "",
    "heartbeat_interval_sec": 10,
    "master": {
      "host": "master",
      "port": 3840,
      "allow_insecure_dev": false
    },
    "register": {
      "name": "main-shard",
      "display_name": "Royaume principal",
      "endpoint": "127.0.0.1:3843",
      "udp_endpoint": "",
      "max_capacity": 500,
      "build_version": "docker-dev",
      "game_mode": "pve",
      "ruleset": "cooperative",
      "region": "eu-west"
    }
  },
  "log": {
    "level": "info",
    "console": true,
    "file": "logs/lcdlln_shard.log"
  },
  "paths": { "content": "game/data" },
  "world": {
    "_comment": "Zone hébergée par ce shard. Le shard résout game/data/zones/<active_zone>/respawn_points.txt (cimetières/auberges par-zone, ServerApp::InitRespawnPoints).",
    "active_zone": "feyhin"
  }
}
